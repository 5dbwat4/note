[2101.938459, "o", "\u001b[A\u001b[10C\u001b[32mo\u001b[32mb\u001b[32mj\u001b[39mcopy -O binary -j .text test_excel.elf imem.bin\u001b[K\u001b[1B\r\u001b[K\u001b[1B\u001b[L# 3. 提取 DMEM 初始数据 (如果有 .bss 这里不提取，由 Excel 的空单元格默认 0 代替)\u001b[1B\u001b[62D\u001b[32mo\u001b[32mb\u001b[32mj\u001b[39mcopy -O binary -j .rodata -j .data test_excel.elf dmem.bin\u001b[K\u001b[1B\r\u001b[K\u001b[1B\u001b[39m#\u001b[39m \u001b[39m4\u001b[39m.\u001b[39m \u001b[39m转\u001b[39m\u001b[39m成\u001b[39m\u001b[39m十\u001b[39m\u001b[39m进\u001b[39m\u001b[39m制\u001b[39m\u001b[39m文\u001b[39m\u001b[39m本\u001b[39m\u001b[39m（调用之前的 python 脚本）                          \u001b[1B\rpython bin2excel.py imem.bin > excel\u001b[32m_imem.txt\u001b[39m\u001b[K\u001b[1B\r\u001b[32mpython bin\u001b[39m2excel.py dmem.bin > excel_dmem.txt\u001b[K\u001b[7A\u001b[65C"]
[2102.473231, "o", "\u001b[48D\u001b[32mj\u001b[32mc\u001b[32mo\u001b[32mp\u001b[32my\u001b[39m\u001b[2B\r\u001b[1m\u001b[30m#\u001b[1m\u001b[30m \u001b[1m\u001b[30m3\u001b[1m\u001b[30m.\u001b[1m\u001b[30m \u001b[1m\u001b[30m提\u001b[1m\u001b[30m\u001b[1m\u001b[30m取\u001b[1m\u001b[30m\u001b[1m\u001b[30m \u001b[1m\u001b[30mD\u001b[1m\u001b[30mM\u001b[1m\u001b[30mE\u001b[1m\u001b[30mM\u001b[1m\u001b[30m \u001b[1m\u001b[30m初\u001b[1m\u001b[30m\u001b[1m\u001b[30m始\u001b[1m\u001b[30m\u001b[1m\u001b[30m数\u001b[1m\u001b[30m\u001b[1m\u001b[30m据\u001b[1m\u001b[30m\u001b[1m\u001b[30m \u001b[1m\u001b[30m(\u001b[1m\u001b[30m如\u001b[1m\u001b[30m\u001b[1m\u001b[30m果\u001b[1m\u001b[30m\u001b[1m\u001b[30m有\u001b[1m\u001b[30m\u001b[1m\u001b[30m \u001b[1m\u001b[30m.\u001b[1m\u001b[30mb\u001b[1m\u001b[30ms\u001b[1m\u001b[30ms\u001b[1m\u001b[30m \u001b[1m\u001b[30m这\u001b[1m\u001b[30m\u001b[1m\u001b[30m里\u001b[1m\u001b[30m\u001b[1m\u001b[30m不\u001b[1m\u001b[30m\u001b[1m\u001b[30m提\u001b[1m\u001b[30m\u001b[1m\u001b[30m取\u001b[1m\u001b[30m\u001b[1m\u001b[30m，\u001b[1m\u001b[30m\u001b[1m\u001b[30m由\u001b[1m\u001b[30m\u001b[1m\u001b[30m \u001b[1m\u001b[30mE\u001b[1m\u001b[30mx\u001b[1m\u001b[30mc\u001b[1m\u001b[30me\u001b[1m\u001b[30ml\u001b[1m\u001b[30m \u001b[1m\u001b[30m的\u001b[1m\u001b[30m\u001b[1m\u001b[30m空\u001b[1m\u001b[30m\u001b[1m\u001b[30m单\u001b[1m\u001b[30m\u001b[1m\u001b[30m元\u001b[1m\u001b[30m\u001b[1m\u001b[30m格\u001b[1m\u001b[30m\u001b[1m\u001b[30m默\u001b[1m\u001b[30m\u001b[1m\u001b[30m认\u001b[1m\u001b[30m\u001b[1m\u001b[30m \u001b[1m\u001b[30m0\u001b[1m\u001b[30m \u001b[1m\u001b[30m代\u001b[1m\u001b[30m\u001b[1m\u001b[30m替\u001b[1m\u001b[30m\u001b[1m\u001b[30m)\u001b[0m\u001b[39m\u001b[1B\u001b[60D\u001b[32mj\u001b[32mc\u001b[32mo\u001b[32mp\u001b[32my\u001b[39m\u001b[2B\r\u001b[1m\u001b[30m#\u001b[1m\u001b[30m \u001b[1m\u001b[30m4\u001b[1m\u001b[30m.\u001b[1m\u001b[30m \u001b[1m\u001b[30m转\u001b[1m\u001b[30m\u001b[1m\u001b[30m成\u001b[1m\u001b[30m\u001b[1m\u001b[30m十\u001b[1m\u001b[30m\u001b[1m\u001b[30m进\u001b[1m\u001b[30m\u001b[1m\u001b[30m制\u001b[1m\u001b[30m\u001b[1m\u001b[30m文\u001b[1m\u001b[30m\u001b[1m\u001b[30m本\u001b[1m\u001b[30m\u001b[1m\u001b[30m（\u001b[1m\u001b[30m\u001b[1m\u001b[30m调\u001b[1m\u001b[30m\u001b[1m\u001b[30m用\u001b[1m\u001b[30m\u001b[1m\u001b[30m之\u001b[1m\u001b[30m\u001b[1m\u001b[30m前\u001b[1m\u001b[30m\u001b[1m\u001b[30m的\u001b[1m\u001b[30m\u001b[1m\u001b[30m \u001b[1m\u001b[30mp\u001b[1m\u001b[30my\u001b[1m\u001b[30mt\u001b[1m\u001b[30mh\u001b[1m\u001b[30mo\u001b[1m\u001b[30mn\u001b[1m\u001b[30m \u001b[1m\u001b[30m脚\u001b[1m\u001b[30m\u001b[1m\u001b[30m本\u001b[1m\u001b[30m\u001b[1m\u001b[30m）\u001b[0m\u001b[39m\u001b[1m\u001b[30m\u001b[0m\u001b[39m\u001b[1B\r\u001b[32mp\u001b[32my\u001b[32mt\u001b[32mh\u001b[32mo\u001b[32mn\u001b[39m\u001b[23C\u001b[33m>\u001b[39m\u001b[6C\u001b[39m_\u001b[39mi\u001b[39mm\u001b[39me\u001b[39mm\u001b[39m.\u001b[39mt\u001b[39mx\u001b[39mt\u001b[1B\u001b[40D\u001b[32mn\u001b[39m\u001b[39m \u001b[39mb\u001b[39mi\u001b[39mn\u001b[19C\u001b[33m>\u001b[39m\u001b[7A\u001b[80C"]
